{
    "name": "totality",
    "version": "0.4.4",
    "type": "module",
    "description": "Analyze media library quality and recommend upgrades",
    "main": "dist-electron/main/index.cjs",
    "scripts": {
        "postinstall": "electron-builder install-app-deps",
        "dev": "vite",
        "build": "tsc && vite build && cross-env NODE_OPTIONS=--no-deprecation electron-builder",
        "lint": "eslint",
        "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
        "preview": "vite preview",
        "electron:dev": "vite",
        "electron:build": "tsc && vite build && cross-env NODE_OPTIONS=--no-deprecation electron-builder",
        "generate-icons": "node scripts/generate-icons.js",
        "test": "vitest",
        "test:run": "vitest run",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "release": "standard-version"
    },
    "keywords": [
        "media",
        "quality",
        "upgrade",
        "electron",
        "plex",
        "jellyfin",
        "emby"
    ],
    "author": "",
    "license": "MIT",
    "sideEffects": false,
    "dependencies": {
        "@libsql/client": "^0.17.3",
        "drizzle-orm": "^0.45.2",
        "electron-updater": "^6.8.9",
        "mysql2": "^3.22.6"
    },
    "overrides": {
        "follow-redirects": "1.16.0",
        "protobufjs": "^8.7.0"
    },
    "devDependencies": {
        "@dnd-kit/core": "6.3.1",
        "@dnd-kit/modifiers": "9.0.0",
        "@dnd-kit/sortable": "10.0.0",
        "@dnd-kit/utilities": "3.2.2",
        "@eslint/js": "10.0.1",
        "@google/genai": "^2.11.0",
        "@tailwindcss/postcss": "^4.3.0",
        "@testing-library/dom": "10.4.1",
        "@testing-library/react": "16.3.2",
        "@types/adm-zip": "0.5.8",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/coverage-istanbul": "^4.1.6",
        "@vitest/coverage-v8": "^4.1.6",
        "@vitest/ui": "^4.1.6",
        "adm-zip": "^0.6.0",
        "axios": "^1.16.1",
        "cross-env": "10.1.0",
        "cssnano": "^8.0.1",
        "drizzle-kit": "^0.31.10",
        "electron": "^43.1.0",
        "electron-builder": "^26.15.3",
        "esbuild": "^0.28.1",
        "eslint": "^10.7.0",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "happy-dom": "^20.10.6",
        "lucide-react": "^1.16.0",
        "postcss": "^8.5.14",
        "prettier": "^3.9.5",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-virtualized-auto-sizer": "2.0.3",
        "react-virtuoso": "^4.18.7",
        "sharp": "^0.35.3",
        "standard-version": "9.5.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^7.0.2",
        "typescript-eslint": "^8.59.4",
        "vite": "^8.1.4",
        "vite-plugin-electron": "^1.1.0",
        "vite-plugin-electron-renderer": "^1.0.0",
        "vitest": "^4.1.6",
        "zod": "^4.4.3"
    }
}
