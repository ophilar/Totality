{
    "name": "totality",
    "version": "0.4.4",
    "type": "module",
    "description": "Analyze media library quality and recommend upgrades",
    "main": "dist-electron/main/index.cjs",
    "scripts": {
        "postinstall": "electron-builder install-app-deps",
        "dev": "vite",
        "build": "tsc && vite build && cross-env NODE_OPTIONS=--no-deprecation electron-builder",
        "lint": "eslint",
        "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
        "preview": "vite preview",
        "electron:dev": "vite",
        "electron:build": "tsc && vite build && cross-env NODE_OPTIONS=--no-deprecation electron-builder",
        "generate-icons": "node scripts/generate-icons.js",
        "test": "vitest",
        "test:run": "vitest run",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "release": "standard-version"
    },
    "keywords": [
        "media",
        "quality",
        "upgrade",
        "electron",
        "plex",
        "jellyfin",
        "emby"
    ],
    "author": "",
    "license": "MIT",
    "sideEffects": false,
    "dependencies": {
        "@libsql/client": "0.14.0",
        "drizzle-orm": "^0.45.2",
        "electron-updater": "6.8.3",
        "mysql2": "3.22.3"
    },
    "overrides": {
        "follow-redirects": "1.16.0",
        "protobufjs": "7.5.5"
    },
    "devDependencies": {
        "@dnd-kit/core": "6.3.1",
        "@dnd-kit/modifiers": "9.0.0",
        "@dnd-kit/sortable": "10.0.0",
        "@dnd-kit/utilities": "3.2.2",
        "@eslint/js": "10.0.1",
        "@google/genai": "1.51.0",
        "@tailwindcss/postcss": "4.2.4",
        "@testing-library/dom": "10.4.1",
        "@testing-library/react": "16.3.2",
        "@types/adm-zip": "0.5.8",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.1",
        "@vitest/coverage-istanbul": "4.1.5",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "adm-zip": "0.5.16",
        "axios": "1.16.0",
        "cross-env": "10.1.0",
        "cssnano": "7.1.8",
        "drizzle-kit": "^0.31.10",
        "electron": "41.5.0",
        "electron-builder": "26.9.0",
        "esbuild": "0.28.0",
        "eslint": "10.3.0",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-react-refresh": "0.5.2",
        "globals": "17.6.0",
        "happy-dom": "20.9.0",
        "lucide-react": "1.14.0",
        "postcss": "8.5.13",
        "prettier": "3.8.3",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-virtualized-auto-sizer": "2.0.3",
        "react-virtuoso": "4.18.6",
        "sharp": "0.34.5",
        "standard-version": "9.5.0",
        "tailwindcss": "4.2.4",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.1",
        "vite": "8.0.10",
        "vite-plugin-electron": "0.29.1",
        "vite-plugin-electron-renderer": "0.14.7",
        "vitest": "4.1.5",
        "zod": "4.4.2"
    }
}
